# ──────────────────────────────────────────────────────────────
# WEAR-RAG .gitignore
# ──────────────────────────────────────────────────────────────

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ── Virtual environment ──────────────────────────────────────
.venv/
venv/
ENV/

# ── Model caches (large binaries — do NOT commit) ────────────
hf_cache/
hf_cache_run2/
hf_cache_run3/
hf_cache_run4/
local_pkgs/
local_pkgs_run2/
local_pkgs_run3/
local_pkgs_run4/

# ── FAISS index (regenerated at runtime) ─────────────────────
faiss_index/

# ── Uploads (user data at runtime) ───────────────────────────
uploads/

# ── IDE / Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── pytest cache ─────────────────────────────────────────────
.pytest_cache/

# ── LaTeX build artifacts ────────────────────────────────────
*.aux
*.log
*.out
*.synctex.gz
*.bbl
*.blg
*.fls
*.fdb_latexmk

# ── OS artifacts ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Misc temp / one-off files ────────────────────────────────
shell_test.txt
eval_*.log
*.trace.log
debug_import.py
test_sample.pdf
scripts/
RESEARCH PAPER PLAG AND AI TEXT.docx

# ── Figure generation scripts (one-off, not part of pipeline)─
fix_fig5.py
generate_before_after_fig.py
generate_extra_figures.py
generate_paper_figures.py

# ── Evaluation runner scripts (one-off) ──────────────────────
run_eval_100_stub_system.py
run_full_eval.py
mock_pipeline.py
eval_checkpoints/

# ── Paper drafts (only final PDF kept) ───────────────────────
research_paper_wear_rag.md
WEAR_RAG_Research_Paper*
WEAR_RAG_IEEE_Final.tex
wear_rag_ieee_paper.*
wear_rag_refs.bib

# ── Loose results / images (kept in eval_results/ & paper_figures/) ─
results_baseline_rag.csv
results_wear-rag.csv
wear_rag_comparison.png
wear_rag_metrics.png

# ── Duplicate / old webapp ───────────────────────────────────
wear_rag_webapp/
templates/demo.html
